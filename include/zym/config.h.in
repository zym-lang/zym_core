/*
 * zym/config.h — generated by CMake from config.h.in
 *
 * DO NOT EDIT the generated file; edit `include/zym/config.h.in` and
 * `cmake/Features.cmake` in the zym_core source tree.
 *
 * Exposes the compile-time feature flags that gate the LSP-facing surface
 * of zym_core.
 *
 * Every other public zym_core header that depends on a flag-gated type
 * includes this file first and guards with `#if ZYM_HAS_*`.
 */
#ifndef ZYM_CONFIG_H
#define ZYM_CONFIG_H

#ifdef __cplusplus
extern "C" {
#endif

/* ---------------------------------------------------------------------------
 * Feature flags.
 *
 * Each macro is always defined and evaluates to 0 or 1. This lets header and
 * source code use `#if ZYM_HAS_FOO` uniformly without `#ifdef` / `#ifndef`
 * confusion. A flag of 0 means the corresponding tooling surface is not
 * linked into this build — the types, functions, and strings it covers are
 * absent and must not be referenced.
 * ------------------------------------------------------------------------- */

#define ZYM_HAS_LSP_SURFACE          @_ZYM_ENABLE_LSP_SURFACE_01@
#define ZYM_HAS_PARSE_TREE_RETENTION @_ZYM_ENABLE_PARSE_TREE_RETENTION_01@
#define ZYM_HAS_SYMBOL_TABLE         @_ZYM_ENABLE_SYMBOL_TABLE_01@
#define ZYM_HAS_NATIVE_METADATA      @_ZYM_ENABLE_NATIVE_METADATA_01@
#define ZYM_HAS_DIAGNOSTIC_CODES     @_ZYM_ENABLE_DIAGNOSTIC_CODES_01@

/* Test-only: must remain 0 in every shipping build. Gates the compiler
 * resolution-trace hook that drives the Phase 4.5 parity test. */
#define ZYM_HAS_BUILD_TESTING        @_ZYM_ENABLE_BUILD_TESTING_01@

/* ---------------------------------------------------------------------------
 * zymConfigSummary()
 *
 * Returns a NUL-terminated, statically allocated string describing the
 * active feature flag set, suitable for embedding in `zym --version
 * --verbose` output or an LSP server handshake. The returned pointer is
 * valid for the lifetime of the process and must not be freed.
 * ------------------------------------------------------------------------- */
const char* zymConfigSummary(void);

#ifdef __cplusplus
} /* extern "C" */
#endif

#endif /* ZYM_CONFIG_H */
